#!/bin/sh
# evalkit plugin launcher — selects the per-platform binary bundled in this dir.
#
# Unlike the lifecycle-hook plugins (which exit 0 when no binary exists, so a
# missing build never traps a turn), evalkit is a *gate*: if it cannot run, the
# caller must NOT treat that as "evals passed". So a missing binary exits 1.
root="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

case "$(uname -s)" in
  Linux)  os=linux ;;
  Darwin) os=darwin ;;
  *)      os="$(uname -s)" ;;
esac
case "$(uname -m)" in
  x86_64|amd64)   arch=x86_64 ;;
  arm64|aarch64)  arch=arm64 ;;
  *)              arch="$(uname -m)" ;;
esac

binary="$root/evalkit-$os-$arch"
if [ ! -x "$binary" ]; then
  echo "evalkit: no bundled binary for $os-$arch ($binary)." >&2
  exit 1
fi
exec "$binary" "$@"
