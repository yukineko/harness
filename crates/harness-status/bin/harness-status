#!/bin/sh
# harness-status plugin launcher — selects the per-platform binary bundled here.
#
# The /status command calls `${CLAUDE_PLUGIN_ROOT}/bin/harness-status <sub>`; this
# dispatcher execs the matching `harness-status-<os>-<arch>` build. If no build
# exists for the host platform it exits 0 silently.
root="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

case "$(uname -s)" in
  Linux)  os=linux ;;
  Darwin) os=darwin ;;
  *)      os="$(uname -s)" ;;
esac
case "$(uname -m)" in
  x86_64|amd64)   arch=x86_64 ;;
  arm64|aarch64)  arch=arm64 ;;
  *)              arch="$(uname -m)" ;;
esac

binary="$root/harness-status-$os-$arch"
if [ ! -x "$binary" ]; then
  echo "harness-status: no bundled binary for $os-$arch ($binary)." >&2
  exit 0
fi
exec "$binary" "$@"
