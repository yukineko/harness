#!/bin/sh
# autoflow plugin launcher — selects the per-platform binary bundled in this dir.
root="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

case "$(uname -s)" in
  Linux)  os=linux ;;
  Darwin) os=darwin ;;
  *)      os="$(uname -s)" ;;
esac
case "$(uname -m)" in
  x86_64|amd64)   arch=x86_64 ;;
  arm64|aarch64)  arch=arm64 ;;
  *)              arch="$(uname -m)" ;;
esac

binary="$root/autoflow-$os-$arch"
if [ ! -x "$binary" ]; then
  echo "autoflow: no bundled binary for $os-$arch ($binary)." >&2
  exit 0
fi
exec "$binary" "$@"
