/target
**/*.rs.bk
Cargo.lock.bak
.DS_Store

# machine-local cargo overrides (e.g. target-dir redirect for a full C: drive
# under WSL) — not something every contributor's machine needs
/.cargo/

# precommit-audit runtime telemetry (append-only, machine-local)
.claude/audit-log.jsonl

# ephemeral session/tool state
.claude/progress.md
.compass/carve-state.json
.compass/outcomes.json

# Python bytecode cache
__pycache__/
*.pyc
