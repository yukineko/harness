// Golden invariants for skill prompts (SKILL.md). Each case pins a hard rule
// that must survive prompt edits — if a refactor silently drops one of these
// guardrails, `evalkit run` goes red before it ships. file paths resolve
// against --root (the repo root). Add a line when you codify a new invariant.
{"id":"flow-keeps-blind-exec-rule","describe":"flow must keep the 盲目実行しない hard rule","file":"crates/flow/skills/flow/SKILL.md","assert":{"contains":["盲目実行しない"]}}
{"id":"flow-keeps-lock-release-rule","describe":"flow must never drop the lock-release guarantee","file":"crates/flow/skills/flow/SKILL.md","assert":{"contains":["ロック解放を絶対に飛ばさない"]}}
{"id":"condukt-keeps-main-consent-rule","describe":"condukt consent stays on the main loop only","file":"crates/condukt/skills/condukt/SKILL.md","assert":{"contains":["合意は main loop のみ"]}}
{"id":"condukt-keeps-completion-gate","describe":"condukt completion is gated by `condukt state gate`","file":"crates/condukt/skills/condukt/SKILL.md","assert":{"contains":["完了は `condukt state gate` が判定"]}}
{"id":"scout-stays-read-only","describe":"scout audit must stay read-only","file":"crates/scout/skills/scout/SKILL.md","assert":{"contains":["監査は read-only"]}}
{"id":"scout-requires-evidence","describe":"scout must not emit measures without evidence","file":"crates/scout/skills/scout/SKILL.md","assert":{"contains":["証拠のない施策"]}}
